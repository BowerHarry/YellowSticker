# Supabase project (service-role key — keep this secret!)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Resend (transactional email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="onboarding@resend.dev"  # Or your verified sending domain address.

# Where alerts go in this MVP. All "standing tickets found" emails are sent
# to this single address until we re-enable per-subscriber notifications.
ALERT_EMAIL="you@example.com"

# Scheduler (defaults baked into the container; override here if you want).
# Cron is evaluated in TZ. Default: every 15 min, 08:00-17:59 Europe/London.
# SCRAPE_CRON="*/15 8-17 * * *"
# TZ="Europe/London"
# SCRAPE_WAIT_MS="15000"
# SCRAPE_INTER_PRODUCTION_DELAY_SEC="30"
# RUN_ON_BOOT="true"
# DRY_RUN="false"   # if true, DB is updated but no emails are sent

# Health endpoint (optional — used by docker healthcheck).
# HEALTH_PORT="3000"

# Chromium mode. Default is headed (runs under Xvfb inside the container)
# because headed Chrome clears Cloudflare challenges much more reliably
# than headless. Set to "true" to force headless if you need to debug.
# SCRAPE_HEADLESS="false"
