# =============================================================================
# Supabase project
# =============================================================================
# Used by both the edge functions (Stripe webhook, subscription mgmt, admin
# dashboard) and by the scraper-service worker running on the Mac mini.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="supabase-service-role-key"
SUPABASE_DB_PASSWORD="your-db-password"

# =============================================================================
# Stripe (used by the web app + Stripe webhook edge function)
# =============================================================================
STRIPE_SECRET_KEY="sk_live_or_test"
STRIPE_PUBLISHABLE_KEY="pk_live_or_test"
STRIPE_WEBHOOK_SECRET="whsec_..."

# =============================================================================
# Resend (used by the scraper-service worker to send alert emails)
# =============================================================================
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="onboarding@resend.dev"  # Or your verified sending domain.

# =============================================================================
# Scraper worker (runs in Docker on a machine you control)
# =============================================================================
# Where alerts are sent in the current MVP (all "standing tickets" emails go
# to this single address until per-subscriber notifications are re-enabled).
ALERT_EMAIL="you@example.com"
# Optional overrides — see scraper-service/env.example for the full list.
# SCRAPE_CRON="*/15 8-17 * * *"
# TZ="Europe/London"
# DRY_RUN="false"

# =============================================================================
# Frontend site (used by the React SPA + by edge functions for email links)
# =============================================================================
PUBLIC_SITE_URL="https://yellowsticker.app"

# =============================================================================
# Admin / monitor dashboard (edge function auth)
# =============================================================================
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme"  # Change this to a strong password!

# =============================================================================
# Status dashboard soft limits (tune to your Supabase + Resend plans)
# =============================================================================
RESEND_DAILY_LIMIT="100"
RESEND_MONTHLY_LIMIT="3000"
SUPABASE_MONTHLY_USER_LIMIT="50000"
SUPABASE_DB_SIZE_LIMIT_BYTES="524288000"
STRIPE_HEALTH_LOOKBACK_DAYS="30"
