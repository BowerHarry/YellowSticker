# VITE_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
VITE_PUBLIC_SUPABASE_FUNCTIONS_URL="https://your-project.supabase.co/functions/v1"
VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Note: Admin credentials are stored in Supabase secrets (ADMIN_USERNAME, ADMIN_PASSWORD)
